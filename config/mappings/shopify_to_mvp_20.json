{
  "source_name": "shopify",
  "target_schema": "mvp_20_column_schema",
  "description": "Field mapping from Shopify raw data into the MVP 20-column canonical schema.",
  "mappings": [
    {
      "raw_field": "shop_name",
      "clean_field": "business_name",
      "canonical_column": "business_name",
      "transformation_rule": "direct_string",
      "notes": "Primary business name from Shopify store profile."
    },
    {
      "raw_field": "primary_category",
      "clean_field": "business_category_raw",
      "canonical_column": "business_category",
      "transformation_rule": "map_to_controlled_business_category",
      "notes": "Map into controlled values like Beauty, Fitness, Fashion, Food, Home, Wellness, Pets, Tech Accessories, Crafts, Education, Other."
    },
    {
      "raw_field": "created_at",
      "clean_field": "event_timestamp",
      "canonical_column": "event_timestamp",
      "transformation_rule": "parse_datetime_to_utc",
      "notes": "Latest anchor timestamp for the Shopify business record."
    },
    {
      "raw_field": "customer_repeat_rate",
      "clean_field": "repeat_customer_signal",
      "canonical_column": "repeat_customer_signal",
      "transformation_rule": "normalize_zero_to_one",
      "notes": "If already percentage, divide by 100. Keep final value between 0.00 and 1.00."
    },
    {
      "raw_field": "product_niche_fit_score",
      "clean_field": "product_category_affinity_raw",
      "canonical_column": "product_category_affinity",
      "transformation_rule": "map_score_to_affinity_bucket",
      "notes": "Map numeric score into Very_Low, Low, Medium, High, Very_High."
    },
    {
      "raw_field": "predicted_micro_niche_1",
      "clean_field": "top_micro_niche_1",
      "canonical_column": "top_micro_niche_1",
      "transformation_rule": "map_to_controlled_micro_niche_list",
      "notes": "Primary niche recommendation."
    },
    {
      "raw_field": "predicted_micro_niche_2",
      "clean_field": "top_micro_niche_2",
      "canonical_column": "top_micro_niche_2",
      "transformation_rule": "map_to_controlled_micro_niche_list_or_none",
      "notes": "Secondary niche recommendation."
    },
    {
      "raw_field": "niche_signal_raw",
      "clean_field": "niche_signal_score",
      "canonical_column": "niche_signal_score",
      "transformation_rule": "normalize_zero_to_one",
      "notes": "Strength of niche signal."
    },
    {
      "raw_field": "visual_score",
      "clean_field": "visual_content_signal",
      "canonical_column": "visual_content_signal",
      "transformation_rule": "normalize_zero_to_one",
      "notes": "Visual appeal and content friendliness score."
    },
    {
      "raw_field": "conversion_efficiency_raw",
      "clean_field": "transaction_conversion_signal",
      "canonical_column": "transaction_conversion_signal",
      "transformation_rule": "normalize_zero_to_one",
      "notes": "Traffic-to-purchase or store conversion strength."
    },
    {
      "raw_field": "primary_platform_prediction",
      "clean_field": "recommended_platform_1",
      "canonical_column": "recommended_platform_1",
      "transformation_rule": "map_to_controlled_platform_list",
      "notes": "Primary recommended platform."
    },
    {
      "raw_field": "secondary_platform_prediction",
      "clean_field": "recommended_platform_2",
      "canonical_column": "recommended_platform_2",
      "transformation_rule": "map_to_controlled_platform_list_or_none",
      "notes": "Secondary recommended platform."
    },
    {
      "raw_field": "platform_fit_raw",
      "clean_field": "platform_fit_score",
      "canonical_column": "platform_fit_score",
      "transformation_rule": "normalize_zero_to_one",
      "notes": "Overall fit score for recommended platform."
    },
    {
      "raw_field": "dense_slice_prediction_1",
      "clean_field": "recommended_dense_slice_1",
      "canonical_column": "recommended_dense_slice_1",
      "transformation_rule": "map_to_controlled_dense_slice_list",
      "notes": "Primary dense slice recommendation."
    },
    {
      "raw_field": "dense_slice_prediction_2",
      "clean_field": "recommended_dense_slice_2",
      "canonical_column": "recommended_dense_slice_2",
      "transformation_rule": "map_to_controlled_dense_slice_list_or_none",
      "notes": "Secondary dense slice recommendation."
    },
    {
      "raw_field": "geo_cluster_type",
      "clean_field": "geography_signal",
      "canonical_column": "geography_signal",
      "transformation_rule": "map_to_controlled_geography_signal",
      "notes": "Allowed values: Hyper_Local, Local, Regional, National, Mixed, Unknown."
    },
    {
      "raw_field": "dense_slice_confidence_raw",
      "clean_field": "dense_slice_confidence",
      "canonical_column": "dense_slice_confidence",
      "transformation_rule": "normalize_zero_to_one",
      "notes": "Confidence in dense-slice recommendation."
    },
    {
      "raw_field": null,
      "clean_field": "data_source_coverage",
      "canonical_column": "data_source_coverage",
      "transformation_rule": "constant_value_shopify_only_or_shopify_and_square_after_merge",
      "notes": "Use Shopify_only in Shopify-only stage output. Upgrade later during canonical merge if Square also contributes."
    }
  ]
}